NODE_ENV=development
PORT=3000

# HubSpot
HUBSPOT_ACCESS_TOKEN=your_token_here
HUBSPOT_CLIENT_SECRET=your_client_secret
HUBSPOT_APP_ID=your_app_id

# MongoDB
MONGODB_URI=mongodb://localhost:27017/hs-webhook

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Queue
QUEUE_CONCURRENCY=5
QUEUE_MAX_RETRIES=3
